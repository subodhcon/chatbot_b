# FastAPI Configuration
PROJECT_NAME="AI Chatbot SaaS API"
API_V1_STR="/api/v1"
ENVIRONMENT="development"  # Options: "development", "production", "testing"

# CORS Configuration (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS="http://localhost:3000,https://example.com"

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chatbot_saas"

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"

# JWT Auth Configuration (generate a secure secret using `openssl rand -hex 32`)
JWT_SECRET_KEY="supersecretchangeinproduction"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI configuration
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4o"

# File Upload Configuration
UPLOAD_DIR="uploads"

# Logging Configuration
LOG_LEVEL="INFO"
